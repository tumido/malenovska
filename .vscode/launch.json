{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev:local",
      "preLaunchTask": "Start Firebase Emulators",
      "postDebugTask": "Stop Firebase Emulators",
      "serverReadyAction": {
        "pattern": "➜  Local:.+(https?://.+)",
        "action": "startDebugging",
        "name": "Launch Chrome session"
      }
    },
    {
      "name": "Launch Chrome session",
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:5173",
      "runtimeArgs": [
        "--remote-debugging-port=9222"
      ]
    }
  ]
}
