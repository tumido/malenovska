{
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "mcp__next-devtools-mcp",
      "mcp__chrome-devtools",
      "Read(//tmp/chrome-devtools-mcp/**)",
      "mcp__eslint",
      "Bash(npm run dev)",
      "Bash(find:*)",
      "Bash(npm run build:*)",
      "Bash(grep:*)",
      "Bash(git show:*)",
      "Bash(npm run lint:*)",
      "Bash(npx tsc:*)",
      "Bash(ls:*)",
      "Bash(git log:*)",
      "Bash(npm view:*)",
      "Bash(npm install:*)",
      "Bash(npx eslint:*)",
      "Bash(npx next:*)",
      "Bash(npm list:*)",
      "Bash(echo \"EXIT: $?\")",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "mcp__ide__getDiagnostics"
    ]
  },
  "enabledMcpjsonServers": [
    "next-devtools-mcp",
    "chrome-devtools",
    "eslint"
  ],
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true
  },
  "enableAllProjectMcpServers": true
}
