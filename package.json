{
  "name": "malenovska",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "dev:local": "VITE_USE_EMULATORS=true react-router dev",
    "build": "react-router build",
    "start": "npx serve build/client -s",
    "lint": "eslint .",
    "typegen": "react-router typegen",
    "emulators": "firebase emulators:start --import=./emulator-data --export-on-exit=./emulator-data",
    "emulators:fresh": "firebase emulators:start",
    "emulators:dump": "node scripts/firestore-dump.mjs && node scripts/storage-dump.mjs",
    "emulators:seed": "node scripts/firestore-seed.mjs && node scripts/storage-seed.mjs",
    "deploy": "firebase deploy",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:rules": "firebase deploy --only firestore:rules"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-router/node": "^7.14.0",
    "clipboard-copy": "^4.0.1",
    "firebase": "^12.11.0",
    "isbot": "^5",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "markdown-to-jsx": "^9.7.13",
    "notistack": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-firebase-hooks": "^5.1.1",
    "react-hook-form": "^7.72.0",
    "react-leaflet": "^5.0.0",
    "react-router": "^7.6.1",
    "react-share": "^5.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-router/dev": "^7.6.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/leaflet": "^1.9.14",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^10.1.0",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^13.29.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
