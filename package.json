{
  "name": "malenovska",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "dev:local": "VITE_USE_EMULATORS=true react-router dev",
    "build": "react-router build",
    "start": "npx serve build/client -s",
    "lint": "eslint .",
    "typegen": "react-router typegen",
    "emulators": "firebase emulators:start --import=./emulator-data --export-on-exit=./emulator-data",
    "emulators:fresh": "firebase emulators:start",
    "emulators:dump": "node scripts/firestore-dump.mjs && node scripts/storage-dump.mjs",
    "emulators:seed": "node scripts/firestore-seed.mjs && node scripts/storage-seed.mjs",
    "deploy": "firebase deploy",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:rules": "firebase deploy --only firestore:rules"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-router/node": "^7.14.1",
    "clipboard-copy": "^4.0.1",
    "firebase": "^12.12.0",
    "isbot": "^5",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "markdown-to-jsx": "^9.7.15",
    "notistack": "^3.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-firebase-hooks": "^5.1.1",
    "react-hook-form": "^7.72.1",
    "react-leaflet": "^5.0.0",
    "react-router": "^7.14.1",
    "react-share": "^5.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-router/dev": "^7.14.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.2.0",
    "firebase-admin": "^13.8.0",
    "firebase-tools": "^15.14.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  }
}
